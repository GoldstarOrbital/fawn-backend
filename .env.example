# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.

# Database
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./fawn.db
# Postgres (swap in later):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/fawn

# Unit sandbox credentials — get from app.s.unit.co after creating a sandbox account
UNIT_API_TOKEN=your_unit_sandbox_token_here
UNIT_BASE_URL=https://api.s.unit.co
UNIT_WEBHOOK_SECRET=your_unit_webhook_secret_here
ALLOW_UNSIGNED_UNIT_WEBHOOKS=false

# Comma-separated domains allowed to call the API from browsers.
ALLOWED_ORIGINS=https://goldstarorbital.github.io,https://goldstarorbital.com,https://www.goldstarorbital.com,http://localhost:3000,http://localhost:3001,http://localhost:8080,http://127.0.0.1:5500

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# JWT signing secret — any long random string. Keep this private.
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Email/password reset
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=alex@getfawn.com

# Admin and payments
ADMIN_API_KEY=your_admin_api_key_here
STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
ALLOW_UNSIGNED_STRIPE_WEBHOOKS=false

# Funding safety. Keep false until external account ownership verification is live.
ALLOW_UNVERIFIED_ACH_FUNDING=false

# ---------------------------------------------------------------------------
# Multi-BaaS provider stack (Column / Lithic / Alpaca / Plaid)
# ---------------------------------------------------------------------------
# All OPTIONAL. Each provider is dormant-but-safe when its key is blank — the
# service client raises "<provider> is not configured" (HTTP 503) instead of
# calling out. Fill in only the providers you've signed with. Unit still fronts
# KYC/onboarding regardless of these.

# Selects the banking backend used by money-movement routes: "unit" | "column"
BAAS_PROVIDER=unit

# Column — banking (deposit accounts, ACH + book transfers). Test-mode vs live
# key selects sandbox vs prod; there is no separate base-url switch.
COLUMN_API_KEY=
COLUMN_BASE_URL=https://api.column.com
COLUMN_WEBHOOK_SECRET=
ALLOW_UNSIGNED_COLUMN_WEBHOOKS=false

# Lithic — card issuing + real-time auth stream
LITHIC_API_KEY=
LITHIC_BASE_URL=https://sandbox.lithic.com/v1
LITHIC_WEBHOOK_SECRET=
ALLOW_UNSIGNED_LITHIC_WEBHOOKS=false

# Alpaca — brokerage / investing (Broker API). Swap base url to
# https://broker-api.alpaca.markets for production.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://broker-api.sandbox.alpaca.markets

# SnapTrade — optional external brokerage connections
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_CONNECTION_TYPE=read

# Plaid — external bank-account linking (funding switching)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_BASE_URL=https://sandbox.plaid.com
